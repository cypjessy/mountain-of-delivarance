{
  "appId": "com.mountainofdeliverance.church",
  "appName": "MOUNTAIN OF DELIVERANCE CHURCH",
  "webDir": "out",
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 0,
      "backgroundColor": "#0F0F0F",
      "androidSplashResourceName": "splash",
      "androidScaleType": "CENTER_CROP"
    },
    "Keyboard": {
      "resize": "none",
      "style": "DARK"
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#0F0F0F",
      "overlaysWebView": true
    },
    "PushNotifications": {
      "presentationOptions": ["badge", "sound", "alert"]
    },
    "LocalNotifications": {
      "smallIcon": "ic_stat_icon",
      "iconColor": "#E8A838"
    },
    "CapacitorHttp": {
      "enabled": false
    }
  }
}
